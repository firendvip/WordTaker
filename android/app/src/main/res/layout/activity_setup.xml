<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/setup_title"
            android:textSize="22sp"
            android:textStyle="bold"
            android:paddingBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/setup_desc"
            android:textSize="15sp"
            android:lineSpacingExtra="4dp"
            android:paddingBottom="24dp" />

        <Button
            android:id="@+id/btnEnableIme"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_enable_ime" />

        <Button
            android:id="@+id/btnPickIme"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/btn_pick_ime" />

        <Button
            android:id="@+id/btnGrantMic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/btn_grant_mic" />

        <EditText
            android:id="@+id/tryHere"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:hint="在此试用：切换到 WordTaker 语音键盘后点麦克风"
            android:minLines="3"
            android:gravity="top"
            android:inputType="textMultiLine"
            android:importantForAutofill="no" />
    </LinearLayout>
</ScrollView>
